# ============================================
# 🐾 PET ID — Environment Variables
# ============================================

# --- Neon PostgreSQL ---
DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/petid?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.neon.tech/petid?sslmode=require"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="petid-uploads"
R2_PUBLIC_URL=""

# --- Resend (E-mail) ---
RESEND_API_KEY=""

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Server Port ---
PORT=3001
